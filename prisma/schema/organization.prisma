// =============================================================================
// Organization, Member, Invitation, Team, TeamMember
// Built on Better Auth's organization plugin (already configured in
// src/lib/auth.ts with teams enabled, dynamic access control, hooks).
// Adds: parentOrganizationId for sub-org hierarchy + denormalized hierarchyPath
// for efficient ancestor/descendant queries.
// =============================================================================

model Organization {
  id                    String         @id @default(cuid(2))

  name                  String
  slug                  String         @unique
  logo                  String?
  metadata              Json?          @default("{}")

  // ---- Sub-organization hierarchy ----
  // A parent org can have many child orgs. Each child has exactly one parent.
  // Root orgs have parentOrganizationId = null.
  parentOrganizationId  String?
  parent                Organization?  @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: Restrict)
  children              Organization[] @relation("OrganizationHierarchy")

  // Denormalized materialized path: e.g. "/{rootId}/{parentId}/{thisId}"
  // Enables single-query ancestor/descendant lookups.
  hierarchyPath         String?
  depth                 Int            @default(0)

  // ---- Quotas / limits (overridable on children) ----
  maxProjects           Int?
  maxMembers            Int?
  maxTeams              Int?
  maxSubOrganizations   Int?

  // ---- Billing / contact ----
  billingEmail          String?
  contactPhone          String?
  country               String?
  timezone              String?        @default("Asia/Tehran")

  // ---- Lifecycle ----
  isActive              Boolean        @default(true)
  archivedAt            DateTime?

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // ---- Relations ----
  members               Member[]
  invitations           Invitation[]
  teams                 Team[]
  projects              Project[]
  aclRoles              AclRole[]
  aclUserRoles          AclUserRole[]

  @@index([slug])
  @@index([parentOrganizationId])
  @@index([hierarchyPath])
  @@index([isActive])
  @@map("organizations")
}

// Better Auth: organization membership. role is a free-form string so that
// custom roles created via the organization plugin's dynamic access control
// stay first-class (e.g. "billing-admin", "support-lead").
model Member {
  id              String       @id @default(cuid(2))

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  role            String       @default("member")

  // Optional team scoping
  teamId          String?
  team            Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Provenance
  invitedById     String?

  // Activity
  joinedAt        DateTime     @default(now())
  lastActiveAt    DateTime?

  createdAt       DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([role])
  @@index([teamId])
  @@map("members")
}

// Pending / past invitations. Better Auth's organization plugin already issues
// these; cancelPendingInvitationsOnReInvite is enabled in src/lib/auth.ts.
model Invitation {
  id              String            @id @default(cuid(2))

  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email           String
  role            String            @default("member")
  status          InvitationStatus  @default(PENDING)

  teamId          String?
  team            Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)

  inviterId       String
  inviter         User              @relation("InviterInvitations", fields: [inviterId], references: [id], onDelete: Cascade)

  expiresAt       DateTime
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  cancelledAt     DateTime?

  createdAt       DateTime          @default(now())

  @@unique([organizationId, email])
  @@index([email])
  @@index([status, expiresAt])
  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

model Team {
  id              String       @id @default(cuid(2))
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  isDefault       Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  members         Member[]
  teamMembers     TeamMember[]
  invitations     Invitation[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

// Optional n-to-n team membership (Better Auth supports either Member.teamId or
// a TeamMember row; we keep both shapes for flexibility).
model TeamMember {
  id        String   @id @default(cuid(2))
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      String   @default("member")

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}
