// =============================================================================
// UserDevice — multi-device management surfaced in the admin panel.
//
// NOTE: there is intentionally NO `Session` model here. Better Auth is wired
// with `secondaryStorage` (Redis) in src/lib/auth.ts, so all session state
// lives in Redis. `get-tables.mjs` in @better-auth/core skips the session
// table when secondaryStorage is set and `session.storeSessionInDatabase`
// isn't explicitly true.
//
// UserDevice is OUR registry: every time a new fingerprint signs in we upsert
// a row here and link the Redis session value's `deviceId` to it. The admin
// "Devices" tab reads this table; revocations are done in Redis (revoke that
// session) AND here (`revokedAt` so future sessions can't reuse the device).
// =============================================================================

model UserDevice {
  id              String     @id @default(cuid(2))
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stable hashed fingerprint of the device (computed app-side from UA, screen, fonts, etc.)
  fingerprint     String

  // Display in admin panel
  name            String?    // user-set, e.g. "Ali's MacBook Pro"
  deviceType      DeviceType @default(UNKNOWN)
  os              String?    // "macOS 15.5", "iOS 18", "Android 14"
  osVersion       String?
  browser         String?
  browserVersion  String?
  manufacturer    String?    // "Apple", "Samsung"
  model           String?    // "iPhone 16 Pro"

  // Trust signals — used by 2FA's "trust this device for 30 days"
  trusted         Boolean    @default(false)
  trustedUntil    DateTime?

  // Last seen
  lastSeenAt      DateTime   @default(now())
  lastSeenIp      String?
  lastSeenCountry String?

  // Revocation (admin can revoke a device, killing all its future sign-ins)
  revokedAt       DateTime?
  revokedReason   String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([userId, fingerprint])
  @@index([userId, lastSeenAt])
  @@index([trusted])
  @@map("user_devices")
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  TV
  WATCH
  BOT
  UNKNOWN
}
