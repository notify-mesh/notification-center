// =============================================================================
// Verification — Better Auth verification tokens
// Covers email-verify, password-reset, phone-OTP-via-Better-Auth, magic links.
// Notification-Center's standalone OTP service (Feature 05) stores its codes in
// Redis only; this table is exclusively for the auth plugin's own flows.
// =============================================================================

model Verification {
  id          String   @id @default(cuid(2))

  identifier  String   // email, username, or phone-E164
  value       String   // HMAC of the token / OTP — never the plaintext
  type        String?  // "email" | "phone" | "password-reset" | "magic-link"

  attempts    Int      @default(0)
  maxAttempts Int      @default(5)

  expiresAt   DateTime
  consumedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}
