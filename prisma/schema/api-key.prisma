// =============================================================================
// ApiKey — credential issued per (project, environment) with rotation support.
//
// Storage rules:
//   - The plaintext token is shown to the user EXACTLY ONCE on creation.
//   - keyHash stores HMAC-SHA256(token, serverPepper). Lookups use keyHash.
//   - keyPrefix stores the first 8 displayable chars for masked UI display
//     (e.g. "nc_live_xxxxxxxx****abcd").
//
// One environment can hold many ApiKey rows (rotation, named purposes).
// =============================================================================

model ApiKey {
  id                String              @id @default(cuid(2))

  name              String
  description       String?

  // ---- Secret material ----
  keyHash           String              @unique
  keyPrefix         String              // first 8 chars of the displayable token

  // ---- Lifecycle ----
  isActive          Boolean             @default(true)
  expiresAt         DateTime?
  lastUsedAt        DateTime?

  // Rotation: deprecatedAt is set when a successor key is issued; the
  // original is kept alive for `gracePeriodHours` before auto-revoke.
  deprecatedAt      DateTime?
  revokedAt         DateTime?
  revokedReason     String?
  revokedByUserId   String?

  rotatedFromKeyId  String?
  rotatedFromKey    ApiKey?             @relation("ApiKeyRotation", fields: [rotatedFromKeyId], references: [id], onDelete: SetNull)
  rotatedTo         ApiKey[]            @relation("ApiKeyRotation")

  // ---- Ownership ----
  organizationId    String              // denormalized for cross-org analytics
  projectId         String
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId     String
  environment       ProjectEnvironment  @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  userId            String              // creator / responsible user
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ---- Metadata + tags ----
  metadata          Json?               @default("{}")
  tags              Json?               @default("[]")

  // ---- Permission gates ----
  canRead           Boolean             @default(true)
  canWrite          Boolean             @default(false)

  // CASL-friendly scope list (free-form strings, e.g. "sms.send", "templates.read")
  scopes            Json?               @default("[]")

  // ---- Network restrictions ----
  ipRestrictions      Json?             @default("[]") // IP/CIDR list
  countryRestrictions Json?             @default("[]") // ISO-3166-1 alpha-2
  restrictionMode     String?           @default("allow") // "allow" | "deny"
  originRestrictions  Json?             @default("[]") // structured: [{ origin, methods, paths }]
  websiteOrigins      Json?             @default("[]") // allowed Origin headers
  allowedUserAgents   Json?             @default("[]")
  blockedUserAgents   Json?             @default("[]")
  allowedMethods      Json?             @default("[\"GET\",\"POST\"]")
  requireHttps        Boolean           @default(false)

  // ---- Quotas (windowed) ----
  minuteQuota       Int?
  hourQuota         Int?
  dailyQuota        Int?
  monthlyQuota      Int?

  // ---- Per-second rate limit (token bucket) ----
  rateLimitPerSecond Int?               @default(10)

  // ---- Current windowed usage counters (reconciled from Redis every 15s) ----
  currentMinuteUsage  Int               @default(0)
  currentHourUsage    Int               @default(0)
  currentDailyUsage   Int               @default(0)
  currentMonthlyUsage Int               @default(0)
  lastQuotaResetAt    DateTime          @default(now())

  // ---- Observability / alerting ----
  enableAnalytics   Boolean             @default(true)
  alertThresholds   Json?               @default("{}") // { minuteUsagePct: 80, dailyUsagePct: 90 }
  webhookUrl        String?
  webhookEvents     Json?               @default("[]")

  // ---- Lifetime metrics ----
  totalCalls        Int                 @default(0)
  successfulCalls   Int                 @default(0)
  failedCalls       Int                 @default(0)
  lastFailedAt      DateTime?
  lastFailureReason String?

  // Latency (rolling)
  avgResponseTimeMs Int                 @default(0)
  p95ResponseTimeMs Int                 @default(0)
  p99ResponseTimeMs Int                 @default(0)

  // Security counters
  securityViolations    Int             @default(0)
  lastSecurityViolation DateTime?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // ---- Relations ----
  notificationJobs  NotificationJob[]
  notifications     Notification[]

  @@index([keyHash])
  @@index([keyPrefix])
  @@index([environmentId])
  @@index([projectId])
  @@index([organizationId])
  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([deprecatedAt])
  @@index([revokedAt])
  @@map("api_keys")
}

// Persistent rate-limit windows (Redis is source-of-truth in flight; this
// table backs the analytics charts and survives a Redis flush).
model ApiKeyRateLimit {
  id        String   @id @default(cuid(2))
  apiKeyId  String
  windowKey String   // "{apiKeyId}:{windowType}:{epochBucket}"
  count     Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([apiKeyId, windowKey])
  @@index([expiresAt])
  @@map("api_key_rate_limits")
}

// Per-window usage history (minute/hour/day/month). Powers analytics charts.
model ApiKeyQuotaWindow {
  id           String   @id @default(cuid(2))
  apiKeyId     String
  windowType   String   // "minute" | "hour" | "day" | "month"
  windowStart  DateTime
  windowEnd    DateTime
  usageCount   Int      @default(0)
  successCount Int      @default(0)
  failureCount Int      @default(0)
  quotaLimit   Int?
  isExceeded   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([apiKeyId, windowType, windowStart])
  @@index([windowEnd])
  @@index([apiKeyId])
  @@map("api_key_quota_windows")
}

// Daily geographic rollup (feeds Feature 13's geo heatmap).
model ApiKeyGeoStats {
  id              String   @id @default(cuid(2))
  apiKeyId        String
  date            DateTime
  country         String
  region          String?
  city            String?

  requestCount    Int      @default(0)
  successCount    Int      @default(0)
  errorCount      Int      @default(0)

  avgResponseTime Int      @default(0)
  totalBytes      BigInt   @default(0)

  metadata        Json?    @default("{}")

  @@unique([apiKeyId, date, country, region, city])
  @@index([date])
  @@index([country])
  @@map("api_key_geo_stats")
}
