// =============================================================================
// ProviderCredential — encrypted vault per (project, environment, providerKey)
//
// Envelope encryption:
//   • Per-row 32-byte DEK (data encryption key), generated at insert.
//   • Each secret field is AES-256-GCM-encrypted with the DEK; the DEK
//     itself is AES-256-GCM-wrapped with a master KEK derived via HKDF
//     from `BETTER_AUTH_SECRET` (see `src/lib/crypto-vault.ts`).
//   • Stored shape (`payload`):
//       {
//         fields: {  // secret fields only
//           "<name>": { iv: base64, ct: base64, tag: base64 }
//         },
//         plain: {   // non-secret fields plaintext (e.g. host, port)
//           "<name>": <value>
//         }
//       }
//   • Rotation: introduce KEK v2 → re-wrap DEKs lazily on next read.
// =============================================================================

model ProviderCredential {
  id              String   @id @default(cuid(2))

  // ---- Scope ----
  organizationId  String       // denormalised for cross-org analytics / RBAC
  projectId       String
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String
  environment     ProjectEnvironment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // ---- Identity ----
  // Provider catalogue key — e.g. "kavenegar", "adp-digital", "bale",
  // "resend", "smtp", "vapid". Lower-case, dash-separated.
  providerKey     String

  // Optional display label so the same provider can be configured twice
  // in one env (e.g. two Kavenegar accounts).
  label           String?              // null = "primary"

  // ---- Encrypted material ----
  // base64 of (iv || ciphertext || authTag) — AES-256-GCM wrapping of the DEK.
  wrappedDek      String   @db.Text
  // KEK version that produced `wrappedDek`. Bumped on rotation; readers
  // accept either v1 or v2 transparently.
  kekVersion      Int      @default(1)
  // Encrypted secret fields + plaintext non-secret fields. See doc above.
  payload         Json

  // ---- Status ----
  // Last result of the provider's `test()` adapter. UI shows a badge.
  status          ProviderCredentialStatus @default(UNTESTED)
  lastTestedAt    DateTime?
  lastError       String?  @db.Text

  // Free-form metadata (cost overrides, sender defaults, etc.).
  metadata        Json?    @default("{}")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Only one credential per (project, environment, providerKey, label).
  @@unique([projectId, environmentId, providerKey, label])
  @@index([organizationId])
  @@index([providerKey])
  @@map("provider_credentials")
}

enum ProviderCredentialStatus {
  UNTESTED
  HEALTHY
  FAILING
  REVOKED
}
