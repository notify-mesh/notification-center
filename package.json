  "scripts": {
    "dev": "bun --bun run next dev",
    "build": "bun --bun run next build",
    "start": "bun --bun run next start",
    "auth:info": "bunx --bun @better-auth/cli info",
    "auth:generate": "bunx --bun @better-auth/cli generate",
    "auth:migrate": "bunx --bun @better-auth/cli migrate",
    "db:view": "prisma studio",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:push:reset": "prisma db push --force-reset",
    "db:seed": "prisma db seed",
    "db:seed:prepare": "prisma db seed -- --prepare",
    "db:seed:prune": "prisma db seed -- --prune",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit --pretty",
    "typegen": "next typegen"
  },
